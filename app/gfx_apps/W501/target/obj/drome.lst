                         467 	.assert 0x0 + (_priv_shutdown_state - _priv_shutdown_state) +0 == 0
                         468 	.assert 0x0 + (_priv_fatal_error_detected - _priv_shutdown_state) +0 == 4
                         469 	.align	2
                         470 	.align	2
                         471 	.align	2
